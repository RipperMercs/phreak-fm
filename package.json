{
  "name": "phreak-fm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run check:emdash && node scripts/fetch-feeds.js && next build",
    "start": "next start",
    "lint": "next lint",
    "check:emdash": "node scripts/check-emdash.js",
    "build:search": "npx ts-node scripts/build-search-index.ts",
