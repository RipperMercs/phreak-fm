# phreak.fm environment variables

# Shared
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5

# Site
NEXT_PUBLIC_SITE_DOMAIN=phreak.fm
NEXT_PUBLIC_SITE_NAME=phreak.fm
NEXT_PUBLIC_SITE_TAGLINE=
